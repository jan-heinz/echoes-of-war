  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b0a59c177f6814c00ab73ce4f9902353, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NewspaperPopup
  popupRoot: {fileID: 36000223}
  bodyText: {fileID: 1415461956}
  closeButton: {fileID: 990798910}
  newspaperText: "Golden Rose Gazette\nOfficial Newspaper of the Golden Kingdom\n\nThe
    Golden Kingdom\u2019s Ready to Resonate\n\nFor ages, we believed fairy magic
    could only thrive in our resonance hub in the Land of Golden Roses. However,
    when our great explorers, the Wings of the Golden Kingdom, discovered that fairies
    could safely resonate with points in other territories, a greater truth was revealed:
    our magic was meant to be shared. \n\nAs the Kingdom moves to resonate with points
    across the world, other magical creatures have answered with hostility as they
    guard their hubs and strike our hard-working exploration team. \n\nThese acts
    have forced the Golden Kingdom into war.\n\nTo protect our colonies and guide
    our expansion, the Court of the Golden Kingdom has mobilized its great army,
    the Thorns of the Golden Kingdom, including an innovative decoding team whose
    magic reveals enemy transmissions and hidden intent.\n\nTheir found knowledge
    will light our path as the Golden Kingdom flies forward!\n"
  rustleAudioSource: {fileID: 1237308171}
  rustleClips:
  - {fileID: 8300000, guid: 07474dc8f41774540a1bbccc5379802d, type: 3}
  - {fileID: 8300000, guid: a9a4d9618ab6d46448f2eb5a58b26245, type: 3}
  - {fileID: 8300000, guid: 04bf45163fa6b4b0d8dea38435566461, type: 3}
  rustleVolume: 1
